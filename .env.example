# Copy to .env and fill in. (The real .env is gitignored — never commit secrets.)

# Local libsql/SQLite file. Or a Turso libsql:// URL for production.
DATABASE_URL=file:warbul.db
# DATABASE_AUTH_TOKEN=            # only for hosted Turso

# Better Auth — generate a strong random secret for any real deployment.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pakasir QRIS payment gateway (https://pakasir.com/p/docs)
SLUG=your-pakasir-project-slug
API_KEY=your-pakasir-api-key
